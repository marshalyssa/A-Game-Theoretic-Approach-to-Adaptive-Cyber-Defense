# CTI Feed API Keys
# Get free keys from:
#   AlienVault OTX: https://otx.alienvault.com/ (sign up, go to Settings → API)
#   VirusTotal: https://www.virustotal.com/ (sign up, go to API key in profile)
#   AbuseIPDB: https://www.abuseipdb.com/ (sign up, go to API tab)

OTX_API_KEY=your_otx_api_key_here
VT_API_KEY=your_virustotal_api_key_here
